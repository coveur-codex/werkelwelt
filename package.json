{
  "name": "werkelwelt",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript-Monorepo fuer die Werkelwelt PWA/Web-App.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspace @werkelwelt/math-engine"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
