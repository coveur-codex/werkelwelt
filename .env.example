# Local development defaults only. Override in an untracked .env file for real secrets.
NODE_ENV=development
POSTGRES_DB=werkelwelt
POSTGRES_USER=werkelwelt
POSTGRES_PASSWORD=werkelwelt_dev_password
DATABASE_URL=postgres://werkelwelt:werkelwelt_dev_password@postgres:5432/werkelwelt
REDIS_URL=redis://redis:6379
MINIO_ROOT_USER=werkelwelt
MINIO_ROOT_PASSWORD=werkelwelt_dev_password
S3_ENDPOINT=http://minio:9000
S3_BUCKET=werkelwelt-dev
NEXT_PUBLIC_API_URL=http://localhost:4000
